{
  "name": "ai-companion-desktop-2d",
  "version": "0.2.0",
  "description": "AI Companion Desktop 2D",
  "main": "apps/desktop/main/main.js",
  "private": true,
  "scripts": {
    "start": "node scripts/start-electron.js",
    "dev": "node scripts/start-electron.js",
    "python": "python backend/server.py",
    "build": "electron-builder"
  },
  "dependencies": {
    "@esotericsoftware/spine-webgl": "^4.1.56",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.deskagent.app",
    "win": {
      "target": "nsis"
    },
    "extraResources": [
      {
        "from": "dist/main_server.exe",
        "to": "."
      }
    ]
  }
}
